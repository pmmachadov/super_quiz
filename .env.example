# ==========================================
# Super Quiz - Variables de Entorno
# ==========================================
# Copiar este archivo a .env y completar los valores

# ------------------------------------------
# Backend Configuration
# ------------------------------------------
PORT=3000
NODE_ENV=development

# ------------------------------------------
# MongoDB Configuration
# ------------------------------------------
# Opción 1: MongoDB local
MONGODB_URI=mongodb://localhost:27017/superquiz

# Opción 2: MongoDB Atlas (producción)
# MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/superquiz?retryWrites=true&w=majority

# ------------------------------------------
# Frontend Configuration (opcional)
# ------------------------------------------
# URL del backend para el frontend en desarrollo
# VITE_API_URL=http://localhost:3000

# ------------------------------------------
# Seguridad (para futura implementación de auth)
# ------------------------------------------
# JWT_SECRET=tu_clave_secreta_aqui
# JWT_EXPIRES_IN=7d
